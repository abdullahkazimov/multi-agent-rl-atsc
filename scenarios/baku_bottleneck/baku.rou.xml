<routes>
    <vType id="baku_driver" 
           accel="3.0" decel="8.0" sigma="1.0" 
           length="4.5" minGap="0.2" maxSpeed="30" 
           lcStrategic="0.1" 
           lcCooperative="0.0" 
           lcSpeedGain="50.0" 
           lcKeepRight="0.0"
           lcPushy="1.0"
           impatience="1.0" 
           guiShape="passenger" color="red"/>

    <route id="r_north" edges="tbilisi_ave_wide     salamzade_squeeze to_hasan_aliyev exit_center n1 n2 n3"/>
    <route id="r_south" edges="tbilisi_ave_wide salamzade_squeeze to_hasan_aliyev exit_center s1 s2 s3"/>

    <!-- Demand recalibrated 2026-05-29 (PLAN.md R2). Both flows merge through the
         single-lane `salamzade_squeeze`, capacity ~1900 veh/h (~945 completions/1800s).
         Measured always-green congestion knee: 2x1000 free-flow (q~7), 2x1500
         congested (q~40, throughput at capacity), 2x2000 heavy (q~84). The old
         2x7500 (~8x cap) gridlocked from t=0 with no learnable signal. 2x1500 =
         3000 veh/h sits just over capacity: a standing queue forms under fixed-time,
         giving the metering agent (green/all-red) room to cut delay without an
         unrecoverable jam. -->
    <flow id="f_n" type="baku_driver" route="r_north" begin="0" end="3600" vehsPerHour="1500" departLane="random" departSpeed="max"/>
    <flow id="f_s" type="baku_driver" route="r_south" begin="0" end="3600" vehsPerHour="1500" departLane="random" departSpeed="max"/>
</routes>